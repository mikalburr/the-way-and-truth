---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">

  <!-- ── Static pages ── -->
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>{{ site.url }}/about/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- ── Category pages ── -->
  <url>
    <loc>{{ site.url }}/category/consumer-psychology/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>{{ site.url }}/category/research-methods/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>{{ site.url }}/category/content-strategy/</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- ── Posts ── -->
  {% for post in site.posts %}
  <url>
    <loc>{{ post.url | prepend: site.url }}</loc>
    <lastmod>{% if post.modified_date %}{{ post.modified_date | date: "%Y-%m-%d" }}{% else %}{{ post.date | date: "%Y-%m-%d" }}{% endif %}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
    {% if post.image %}
    <image:image>
      <image:loc>{{ post.image | prepend: site.url }}</image:loc>
      <image:title>{{ post.title | xml_escape }}</image:title>
    </image:image>
    {% endif %}
  </url>
  {% endfor %}

</urlset>
